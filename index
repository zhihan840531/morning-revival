async function loadSummary(idx) {
var body = document.getElementById(‘summaryBody’);
if (!body) return;
if (summaryCache[idx]) { renderSummary(summaryCache[idx]); return; }

var d = DAYS_DATA[idx];
var text = (d.feeding + ‘\n\n’ + d.message).substring(0, 2500);

try {
var res = await fetch(‘https://api.anthropic.com/v1/messages’, {
method: ‘POST’,
headers: { ‘Content-Type’: ‘application/json’ },
body: JSON.stringify({
model: ‘claude-sonnet-4-20250514’,
max_tokens: 1000,
messages: [{ role: ‘user’, content: ‘以下是晨興聖言靈修內容，請用繁體中文整理重點。只輸出純JSON，不要加任何其他文字、標點或markdown符號：\n\n’ + text + ‘\n\n輸出格式如下：\n{“core_verse”:“本段最核心的一節經文或句子（35字內）”,“key_points”:[“重點1（30字內）”,“重點2（30字內）”,“重點3（30字內）”],“application”:“今日默想與應用方向（45字內）”}’ }]
})
});
var data = await res.json();
var raw = ((data.content && data.content[0] && data.content[0].text) || ‘{}’).replace(/`json|`/g, ‘’).trim();
var parsed = JSON.parse(raw);
summaryCache[idx] = parsed;
if (document.getElementById(‘summaryBody’)) renderSummary(parsed);
} catch(e) {
var b = document.getElementById(‘summaryBody’);
if (b) b.innerHTML = ‘<div style="color:var(--ink-faint);font-size:13px;line-height:1.8">AI 整理暫時無法使用，請直接閱讀完整內容。</div>’;
}
}

function renderSummary(s) {
var body = document.getElementById(‘summaryBody’);
if (!body) return;
var html = ‘<ul class="summary-points">’;
(s.key_points || []).forEach(function(pt, i) {
html += ‘<li class="summary-point"><div class="point-bullet">’ + (i+1) + ‘</div><div>’ + esc(pt) + ‘</div></li>’;
});
html += ‘</ul>’;
if (s.core_verse) html += ‘<div class="core-verse">「’ + esc(s.core_verse) + ‘」</div>’;
if (s.application) html += ’<div class="application-box">💭 ’ + esc(s.application) + ‘</div>’;
body.innerHTML = html;
}

