}

function renderTabs() {
  var outlineTab = '<div class="day-tab outline-tab' + (currentDay === -1 ? ' active' : '') + '" onclick="switchDay(-1)">綱目</div>';
  var dayTabs = DAYS_DATA.map(function(d, i) {
    return '<div class="day-tab' + (i === currentDay ? ' active' : '') + '" onclick="switchDay(' + i + ')">' + d.label + '</div>';
  }).join('');
  document.getElementById('dayTabs').innerHTML = outlineTab + dayTabs;
}

function switchDay(idx) {
  currentDay = idx;
  document.querySelectorAll('.day-tab').forEach(function(t, i) {
    t.classList.toggle('active', i === 0 ? idx === -1 : idx === i - 1);
  });
  if (idx === -1) { renderOutlinePage(); } else { renderDay(idx); }
  window.scrollTo(0, 0);
}

