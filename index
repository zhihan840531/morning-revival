function buildOutlineHTML(items) {
  if (!items || !items.length) return '';
  var html = '';
  items.forEach(function(item) {
    if (item.type === 'part') {
      html += '<div class="ol-part">';
      html += '<div class="ol-part-title">' + esc(item.text) + (item.ref ? ' <span class="ref-tag">—' + esc(item.ref) + '</span>' : '') + '</div>';
      if (item.children) html += buildOutlineHTML(item.children);
      html += '</div>';
    } else if (item.type === 'section') {
      html += '<div class="ol-section">';
      html += '<div class="ol-section-title">' + esc(item.text) + (item.ref ? ' <span class="ref-tag">—' + esc(item.ref) + '</span>' : '') + '</div>';
      if (item.children) html += buildOutlineHTML(item.children);
      html += '</div>';
    } else if (item.type === 'sub') {
      html += '<div class="ol-sub">';
      html += '<div class="ol-sub-title"><span style="color:var(--gold-dark);margin-right:4px">' + esc(item.num) + '</span>' + esc(item.text) + (item.ref ? ' <span class="ref-tag">—' + esc(item.ref) + '</span>' : '') + '</div>';
      if (item.children) html += buildOutlineHTML(item.children);
      html += '</div>';
    } else if (item.type === 'bullet') {
      html += '<div class="ol-bullets"><div class="ol-bullet"><span>' + esc(item.text) + (item.ref ? ' <span class="ref-tag">—' + esc(item.ref) + '</span>' : '') + '</span></div></div>';
    }
  });
  return html;
}

