function flattenOutline(items, lines, depth) {
if (!items) return;
var indent = ’  ’.repeat(depth);
items.forEach(function(item) {
var ref = item.ref ? ‘（’ + item.ref + ‘）’ : ‘’;
if (item.type === ‘part’) lines.push(indent + ’▍ ’ + item.text + ref);
else if (item.type === ‘section’) lines.push(indent + item.text + ref);
else if (item.type === ‘sub’) lines.push(indent + item.num + ’ ’ + item.text + ref);
else if (item.type === ‘bullet’) lines.push(indent + ’— ’ + item.text + ref);
if (item.children) flattenOutline(item.children, lines, depth + 1);
});
}

